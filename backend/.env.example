# ============================================================
# BOYAKA BACKEND — Environment Variables
# ============================================================
# Bu faylni ko'chirib .env nomi bilan saqlang:
#   cp .env.example .env
#
# MUHIM: .env faylini git'ga push qilmang!
# ============================================================

# Server
PORT=5000
NODE_ENV=production

# Database (PostgreSQL)
# Railway: avtomatik beriladi
# Local: postgresql://user:password@localhost:5432/boyaka_db
DATABASE_URL=postgresql://username:password@localhost:5432/boyaka_db

# JWT Authentication
# Kamida 32 ta belgi, kuchli parol!
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# Frontend URL (CORS uchun — production domeningiz)
FRONTEND_URL=https://boyaka.vercel.app
# Bir nechta domen kerak bo'lsa, backend/server.js > allowedOrigins ni yangilang

# Backend URL (OAuth callback uchun)
BACKEND_URL=https://boyaka-backend.railway.app

# Google OAuth (ixtiyoriy — Google Console dan oling)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://boyaka-backend.railway.app/api/auth/google/callback

# Email (nodemailer — parol tiklash uchun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@boyaka.app

# Currency API (exchangerate-api.com dan bepul kalit oling)
EXCHANGE_RATE_API_KEY=your_currency_api_key

# Recurring transactions (startup'da ishga tushirish)
PROCESS_RECURRING_ON_STARTUP=false
