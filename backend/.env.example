# ============================================================
# BOYAKA BACKEND — Environment Variables
# ============================================================
# Bu faylni ko'chirib .env nomi bilan saqlang:
#   cp .env.example .env
#
# MUHIM: .env faylini git'ga push qilmang!
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/boyaka_db
# Yoki alohida:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=boyaka_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_this
JWT_EXPIRES_IN=7d

# Frontend URL (CORS uchun)
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://boyaka.app

# Google OAuth (ixtiyoriy)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Email (nodemailer, ixtiyoriy)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@boyaka.app

# Currency API (ixtiyoriy)
CURRENCY_API_KEY=your_currency_api_key

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
