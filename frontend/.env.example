# ============================================================
# BOYAKA FRONTEND — Environment Variables
# ============================================================
# Bu faylni ko'chirib .env nomi bilan saqlang:
#   cp .env.example .env
#
# MUHIM: .env faylini git'ga push qilmang!
# ============================================================

# Backend API URL (production'da o'zgartiring)
# Local: http://localhost:5000
# Production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:5000

# App environment
VITE_APP_ENV=development

# App version (optional)
VITE_APP_VERSION=1.0.0
